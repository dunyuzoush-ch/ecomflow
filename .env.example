# ========================================
# EcomFlow Pro 环境配置模板
# ========================================
# 复制此文件为 .env 并填写你的配置
# cp .env.example .env
# ========================================

# ============ 应用配置 ============
NODE_ENV=production
PORT=3000
BASE_URL=http://localhost:3000

# ============ Shopify 配置 (必需) ============
SHOPIFY_SHOP=ququmob.myshopify.com
SHOPIFY_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_KEY=e63652c5c7285c50b9f6afa3099e38b6
SHOPIFY_API_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============ OpenAI 配置 (必需) ============
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============ WordPress 配置 (SEO需要) ============
# WP_URL=https://yoursite.com
# WP_USER=admin
# WP_PASS=your_app_password

# ============ 数据库配置 ============
DATABASE_URL=postgresql://ecomflow:ecomflow_pass@localhost:5432/ecomflow

# ============ Redis 配置 ============
REDIS_URL=redis://localhost:6379

# ============ OpenClaw 配置 ============
# OPENCLAW_API_KEY=your_openclaw_key

# ============ Meta Ads 配置 (可选) ============
# META_ACCESS_TOKEN=your_token
# META_AD_ACCOUNT_ID=act_xxxxx
# META_PIXEL_ID=xxxxx

# ============ TikTok Ads 配置 (可选) ============
# TIKTOK_ADVERTISER_ID=xxxxx
# TIKTOK_ACCESS_TOKEN=your_token

# ============ Google Ads 配置 (可选) ============
# GOOGLE_CUSTOMER_ID=xxxxx
# GOOGLE_DEVELOPER_TOKEN=your_token

# ============ Twitter/X 配置 (可选) ============
# TWITTER_API_KEY=xxxxx
# TWITTER_API_SECRET=xxxxx
# TWITTER_ACCESS_TOKEN=xxxxx
# TWITTER_ACCESS_SECRET=xxxxx

# ============ TikTok 账号 (可选) ============
# TIKTOK_USERNAME=your_username
# TIKTOK_PASSWORD=your_password

# ============ Pinterest 配置 (可选) ============
# PINTEREST_ACCESS_TOKEN=your_token

# ============ 报警配置 (可选) ============
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_password

# ============ 广告规则 ============
ADS_MIN_ROAS=2.0
ADS_SCALE_ROAS=3.0
ADS_SCALE_MULTIPLIER=1.5

# ============ 内容生成配置 ============
CONTENT_MIN_ARTICLES_PER_DAY=10
CONTENT_MIN_SOCIAL_POSTS_PER_DAY=30

# ============ 产品生成配置 ============
PRODUCTS_MIN_PER_DAY=20
PRODUCTS_MAX_PER_DAY=50
