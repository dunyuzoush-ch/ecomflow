# EcomFlow Environment Variables
# Copy this file to .env and fill in your values

# ============ Shopify ============
SHOPIFY_SHOP=yourstore.myshopify.com
SHOPIFY_TOKEN=your_private_app_access_token

# ============ AI Providers ============
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# ============ Social Media ============
TIKTOK_API_KEY=your_tiktok_api_key
TIKTOK_ADS_ACCOUNT_ID=your_ads_account_id

TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

PINTEREST_API_KEY=your_pinterest_api_key
PINTEREST_ADS_ACCOUNT_ID=your_pinterest_ads_id

# ============ Facebook/Meta Ads ============
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret
FB_ACCESS_TOKEN=your_facebook_access_token
FB_ADS_ACCOUNT_ID=your_facebook_ads_account_id

# ============ WordPress (SEO) ============
WP_URL=https://yoursite.com
WP_USER=admin
WP_PASS=your_wordpress_app_password

# ============ Google Analytics ============
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your_ga_api_secret

# ============ Database (Optional) ============
# DATABASE_URL=postgresql://user:password@localhost:5432/ecomflow

# ============ Redis (Optional) ============
# REDIS_URL=redis://localhost:6379
